# Web app
PORT=3001
HOST=127.0.0.1
APP_API_KEY=pon-una-clave-larga-aqui
NODE_ENV=development

# SECURITY: Required in production for password reset (prevents SSRF attacks)
# APP_URL should be your production URL (e.g., https://gtd-neto.vercel.app)
APP_URL=

# Storage
DATA_DIR=/home/ubuntu/.openclaw/workspace/mi-web-app/data
DB_PATH=/home/ubuntu/.openclaw/workspace/mi-web-app/data/db.json

# OpenClaw

# Supabase (recommended for persistence + authentication)
# WARNING: Keep SERVICE_ROLE_KEY secret - it bypasses RLS policies
# ANON_KEY is safe for client-side use
USE_SUPABASE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_OWNER=default

# Stripe (required for billing — get keys from dashboard.stripe.com)
# Use test keys (sk_test_...) in development, live keys (sk_live_...) in production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Get the webhook secret from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Required events: checkout.session.completed, customer.subscription.updated,
#                  customer.subscription.deleted, invoice.payment_failed
