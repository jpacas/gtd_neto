<div class="max-w-lg">
  <h1 class="text-xl font-bold text-slate-900 mb-6">Mi perfil</h1>

  <!-- Account info -->
  <div class="card mb-4">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Cuenta</h2>
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-semibold text-sm shrink-0">
        <%= authUser.email[0].toUpperCase() %>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-900"><%= authUser.email %></p>
        <p class="text-xs text-slate-500">Usuario desde <%= new Date(authUser.created_at || Date.now()).toLocaleDateString('es', { year: 'numeric', month: 'long' }) %></p>
      </div>
    </div>
  </div>

  <!-- Subscription -->
  <div class="card mb-4">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Suscripción</h2>

    <% if (!subscription) { %>
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">Sin suscripción</span>
      </div>
      <a href="/pricing" class="btn btn-primary text-sm">Ver planes →</a>

    <% } else if (subscription.status === 'trialing') { %>
      <%
        const trialEnd = new Date(subscription.trial_ends_at);
        const daysLeft = Math.ceil((trialEnd - Date.now()) / 86400000);
        const trialActive = trialEnd > new Date();
      %>
      <div class="flex items-center gap-2 mb-3">
        <% if (trialActive) { %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Prueba gratuita</span>
          <span class="text-xs text-slate-500">
            <% if (daysLeft > 0) { %><%= daysLeft %> días restantes<% } else { %>Vence hoy<% } %>
          </span>
        <% } else { %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Prueba expirada</span>
        <% } %>
      </div>
      <% if (trialActive) { %>
        <p class="text-xs text-slate-500 mb-3">Tu período de prueba termina el <strong><%= trialEnd.toLocaleDateString('es', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>.</p>
        <a href="/billing/checkout" class="btn btn-primary text-sm">Suscribirme por $9/mes →</a>
      <% } else { %>
        <a href="/pricing" class="btn btn-primary text-sm">Ver planes →</a>
      <% } %>

    <% } else if (subscription.status === 'active' || subscription.status === 'past_due') { %>
      <div class="flex items-center gap-2 mb-3">
        <% if (subscription.status === 'active') { %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">✓ Activa</span>
        <% } else { %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Pago pendiente</span>
        <% } %>
        <span class="text-xs text-slate-500">$9/mes</span>
      </div>
      <% if (subscription.current_period_end) { %>
        <p class="text-xs text-slate-500 mb-3">
          Próximo cobro: <strong><%= new Date(subscription.current_period_end).toLocaleDateString('es', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>
        </p>
      <% } %>
      <% if (subscription.stripe_customer_id) { %>
        <a href="/billing/portal" class="btn btn-secondary text-sm">Gestionar suscripción / Cancelar →</a>
        <p class="mt-2 text-xs text-slate-400">Procesado por Stripe. Puedes cancelar en cualquier momento.</p>
      <% } %>

    <% } else if (subscription.status === 'canceled') { %>
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Cancelada</span>
      </div>
      <a href="/pricing" class="btn btn-primary text-sm">Reactivar suscripción →</a>

    <% } %>
  </div>

  <!-- Danger zone -->
  <div class="card border-red-100">
    <h2 class="text-sm font-semibold text-red-700 mb-3">Zona peligrosa</h2>
    <p class="text-xs text-slate-500 mb-3">Para eliminar tu cuenta, contacta soporte.</p>
    <form method="POST" action="/auth/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="btn btn-secondary text-sm text-amber-700">🚪 Cerrar sesión</button>
    </form>
  </div>
</div>
