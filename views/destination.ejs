<div class="space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-surface-900 dark:text-surface-50"><%= section.label %></h1>
      <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5"><%= section.hint %></p>
    </div>
    <% if (items.length > 0) { %>
    <span class="text-xs font-medium text-surface-500 dark:text-surface-400"><%= items.length %> elemento<%= items.length === 1 ? '' : 's' %></span>
    <% } %>
  </div>

  <% if (!items.length) { %>
    <div class="card">
      <div class="empty-state">
        <div class="w-16 h-16 rounded-full bg-surface-100 dark:bg-surface-700 flex items-center justify-center mb-4">
          <% if (section.key === 'no-hacer') { %>
            <svg class="w-8 h-8 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          <% } else if (section.key === 'someday') { %>
            <svg class="w-8 h-8 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          <% } else { %>
            <svg class="w-8 h-8 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          <% } %>
        </div>
        <div class="text-base font-semibold text-surface-700 dark:text-surface-200 mb-1">Sin elementos aquí</div>
        <div class="text-sm text-surface-500 dark:text-surface-400 mb-4 max-w-xs">
          <% if (isSomeday) { %>
          Los items que marques como "Algún Día" desde Collect aparecerán aquí.
          <% } else { %>
          Los items que asignes a "<%= section.label %>" desde Collect aparecerán aquí.
          <% } %>
        </div>
        <a href="/collect" class="btn-primary text-sm">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
          Ir a Collect
        </a>
      </div>
    </div>
  <% } %>

  <div class="space-y-2">
    <% for (const it of items) { %>
      <div class="card p-4 flex items-start justify-between gap-3">
        <div class="flex-1 min-w-0">
          <div class="font-medium text-sm text-surface-900 dark:text-surface-100 break-words"><%= it.title || it.input %></div>
          <% if (it.notes) { %>
            <div class="text-xs text-surface-500 dark:text-surface-400 mt-1 whitespace-pre-wrap"><%= it.notes %></div>
          <% } %>
          <% if (it.context || it.area) { %>
            <div class="mt-1.5 flex flex-wrap gap-1">
              <% if (it.context) { %><span class="context-badge"><%= it.context %></span><% } %>
              <% if (it.area) { %><span class="area-badge"><%= it.area %></span><% } %>
            </div>
          <% } %>
        </div>
        <div class="flex items-center gap-1.5 shrink-0">
          <% if (isSomeday) { %>
            <form method="POST" action="/someday/<%= it.id %>/rescue">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn-secondary text-xs">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
                Rescatar
              </button>
            </form>
          <% } %>
          <form method="POST" action="/items/<%= it.id %>/delete" class="delete-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="button" class="btn-danger text-xs delete-item-btn">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              Eliminar
            </button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script nonce="<%= cspNonce %>">
  document.querySelectorAll('.delete-item-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var form = btn.closest('.delete-form');
      if (typeof confirmAction !== 'undefined') {
        confirmAction('¿Eliminar este elemento?', function() { form.submit(); });
      } else {
        if (confirm('¿Eliminar este elemento?')) form.submit();
      }
    });
  });
</script>
