<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Aplicación GTD simplificada para gestión de productividad" />
  <meta name="theme-color" content="#2563eb" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/styles.css" />
  <link rel="manifest" href="/public/manifest.json" />
  <link rel="apple-touch-icon" href="/public/icon-192.png" />
  <!-- Toastify CSS -->
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-slate-900 focus:px-3 focus:py-2 focus:rounded">
    Saltar al contenido principal
  </a>

  <% if (!hideAppNav) { %>
  <!-- Header sticky -->
  <header class="sticky top-0 z-20 bg-white/95 backdrop-blur-sm border-b border-slate-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center h-14 gap-2">

        <!-- Logo -->
        <a href="/" class="text-base font-bold text-slate-900 shrink-0 hover:text-blue-600 transition-colors">
          GTD_Neto
        </a>

        <div class="w-px h-5 bg-slate-200 shrink-0 hidden md:block mx-1"></div>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-0.5 flex-1 overflow-x-hidden" aria-label="Navegación principal">
          <a class="nav-link" href="/" data-page="/">🧭 Dashboard</a>
          <a class="nav-link" href="/hoy" data-page="/hoy">🌅 Hoy</a>
          <a class="nav-link" href="/collect" data-page="/collect">📥 Collect</a>
          <a class="nav-link" href="/hacer" data-page="/hacer">✅ Hacer</a>
          <a class="nav-link" href="/agendar" data-page="/agendar">🗓️ Agendar</a>
          <a class="nav-link" href="/delegar" data-page="/delegar">🤝 Delegar</a>
          <a class="nav-link" href="/desglosar" data-page="/desglosar">🧩 Desglosar</a>
          <a class="nav-link" href="/no-hacer" data-page="/no-hacer">🚫 No hacer</a>
          <a class="nav-link" href="/terminado" data-page="/terminado">🎯 Terminado</a>
          <a class="nav-link" href="/stats" data-page="/stats">📈 Stats</a>
          <a class="nav-link" href="/weekly-review" data-page="/weekly-review">📋 Revisión
            <% if (locals.daysSinceReview != null && locals.daysSinceReview > 7) { %><span class="ml-0.5 w-2 h-2 rounded-full bg-amber-400 animate-pulse inline-block align-middle"></span><% } %>
          </a>
        </nav>

        <!-- Right side: logout + hamburger -->
        <div class="ml-auto flex items-center gap-1 shrink-0">
          <% if (useSupabase && authUser) { %>
            <form method="POST" action="/auth/logout" class="hidden md:block">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="text-xs px-2 py-1 rounded-lg border border-slate-300 bg-white hover:bg-amber-50 text-amber-700 transition-colors">🚪 Salir</button>
            </form>
          <% } %>
          <button id="nav-hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-nav" class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>

      </div>
    </div>

    <!-- Mobile nav (collapsible) -->
    <div id="mobile-nav" class="hidden md:hidden border-t border-slate-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-2 flex flex-col gap-0.5">
        <% if (useSupabase && authUser) { %>
          <div class="flex items-center justify-end py-2 border-b border-slate-200 mb-1">
            <form method="POST" action="/auth/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="text-xs px-2 py-1 rounded-lg border border-slate-300 text-amber-700 hover:bg-amber-50 transition-colors">🚪 Salir</button>
            </form>
          </div>
        <% } %>
        <a class="nav-link-mobile" href="/" data-page="/">🧭 Dashboard</a>
        <a class="nav-link-mobile" href="/hoy" data-page="/hoy">🌅 Hoy</a>
        <a class="nav-link-mobile" href="/collect" data-page="/collect">📥 Collect</a>
        <a class="nav-link-mobile" href="/hacer" data-page="/hacer">✅ Hacer</a>
        <a class="nav-link-mobile" href="/agendar" data-page="/agendar">🗓️ Agendar</a>
        <a class="nav-link-mobile" href="/delegar" data-page="/delegar">🤝 Delegar</a>
        <a class="nav-link-mobile" href="/desglosar" data-page="/desglosar">🧩 Desglosar</a>
        <a class="nav-link-mobile" href="/no-hacer" data-page="/no-hacer">🚫 No hacer</a>
        <a class="nav-link-mobile" href="/terminado" data-page="/terminado">🎯 Terminado</a>
        <a class="nav-link-mobile" href="/stats" data-page="/stats">📈 Stats</a>
        <a class="nav-link-mobile" href="/weekly-review" data-page="/weekly-review">📋 Revisión Semanal</a>
      </div>
    </div>
  </header>
  <% } %>

  <div class="max-w-6xl mx-auto p-4 md:p-6">

    <% if (flash?.error) { %>
      <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-800 text-sm border border-red-200"><%= flash.error %></div>
    <% } %>

    <main id="main-content" class="mt-2" tabindex="-1">
      <%- body %>
    </main>
  </div>

  <!-- Scripts comunes -->
  <script nonce="<%= cspNonce %>" src="/public/js/toast.js"></script>
  <script nonce="<%= cspNonce %>" src="/public/js/utils.js"></script>
  <!-- Toastify JS -->
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <!-- UI Helpers (loading states, toasts) -->
  <script nonce="<%= cspNonce %>" src="/public/js/ui-helpers.js"></script>
  <!-- Global Search -->
  <script nonce="<%= cspNonce %>" src="/public/js/search.js"></script>
  <!-- Keyboard Shortcuts -->
  <script nonce="<%= cspNonce %>" src="/public/js/hotkeys.js"></script>

  <script nonce="<%= cspNonce %>">
    // Active nav indicator
    (function () {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link, .nav-link-mobile').forEach(function (link) {
        if (link.dataset.page === path) link.classList.add('nav-active');
      });
    })();

    // Hamburger menu toggle
    (function () {
      const hamburger = document.getElementById('nav-hamburger');
      const mobileNav = document.getElementById('mobile-nav');
      if (!hamburger || !mobileNav) return;
      hamburger.addEventListener('click', function () {
        const isOpen = !mobileNav.classList.contains('hidden');
        mobileNav.classList.toggle('hidden');
        hamburger.setAttribute('aria-expanded', String(!isOpen));
      });
    })();
  </script>

  <!-- Command Palette (Cmd+K) -->
  <script nonce="<%= cspNonce %>" src="/public/js/command-palette.js"></script>

  <!-- FAB — Captura rápida universal -->
  <% if (!hideAppNav) { %>
  <button id="fab-capture"
    class="fixed bottom-6 right-6 z-40 w-14 h-14 rounded-full bg-blue-600 hover:bg-blue-700 text-white shadow-lg hover:shadow-xl transition-all duration-150 flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2"
    aria-label="Captura rápida"
    onclick="document.getElementById('fab-dialog').showModal()">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
  </button>

  <dialog id="fab-dialog" class="rounded-xl shadow-2xl border border-slate-200 bg-white w-full max-w-md p-0 backdrop:bg-black/50">
    <form method="POST" action="/collect/add">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="p-4">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Captura rápida</h2>
        <textarea name="input" rows="3" autofocus
          class="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 resize-none"
          placeholder="¿Qué tienes en mente?"></textarea>
      </div>
      <div class="flex items-center justify-end gap-2 px-4 pb-4">
        <button type="button" onclick="document.getElementById('fab-dialog').close()"
          class="text-sm px-3 py-1.5 rounded-lg border border-slate-300 bg-white hover:bg-slate-50 transition-colors">Cancelar</button>
        <button type="submit"
          class="text-sm px-3 py-1.5 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors">Agregar</button>
      </div>
    </form>
  </dialog>
  <% } %>

  <!-- PWA Service Worker -->
  <script nonce="<%= cspNonce %>">
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js').catch(function () {});
      });
    }
  </script>

  <!-- Flash message to toast -->
  <% if (flash?.error) { %>
    <script nonce="<%= cspNonce %>">
      document.addEventListener('DOMContentLoaded', function () {
        toast.error(<%- JSON.stringify(String(flash.error || '')) %>);
      });
    </script>
  <% } %>
  <% if (flash?.success) { %>
    <script nonce="<%= cspNonce %>">
      document.addEventListener('DOMContentLoaded', function () {
        toast.success(<%- JSON.stringify(String(flash.success || '')) %>);
      });
    </script>
  <% } %>
</body>
</html>
