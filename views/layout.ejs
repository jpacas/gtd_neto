<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="GTD Neto — Gestión de productividad personal" />
  <meta name="theme-color" content="#0e87f0" />
  <title><%= title %> · GTD_Neto</title>
  <link rel="stylesheet" href="/public/css/styles.css" />
  <link rel="manifest" href="/public/manifest.json" />
  <link rel="apple-touch-icon" href="/public/icon-192.png" />
  <script nonce="<%= cspNonce %>" src="/public/js/theme.js"></script>
</head>
<body class="bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-surface-100 min-h-screen">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-surface-900 focus:px-3 focus:py-2 focus:rounded-lg">
    Saltar al contenido principal
  </a>

  <% if (!hideAppNav) { %>
  <header class="sticky top-0 z-20 bg-white/95 dark:bg-surface-900/95 backdrop-blur-sm border-b border-surface-200 dark:border-surface-800 shadow-sm">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center h-14 gap-2">

        <!-- Logo -->
        <a href="/" class="text-base font-bold text-surface-900 dark:text-surface-100 shrink-0 hover:text-brand-600 dark:hover:text-brand-400 transition-colors flex items-center gap-1.5">
          <svg class="w-5 h-5 text-brand-500" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          GTD_Neto
        </a>

        <div class="w-px h-5 bg-surface-200 dark:bg-surface-700 shrink-0 hidden md:block mx-1"></div>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-0.5 flex-1 overflow-x-auto" aria-label="Navegación principal">
          <% const nc = navCounts || {}; %>
          <a class="nav-link" href="/" data-page="/">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
              Dashboard
            </span>
          </a>
          <a class="nav-link" href="/collect" data-page="/collect">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
              Collect
              <% if (nc.collect) { %><span class="nav-badge-alert"><%= nc.collect %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/hacer" data-page="/hacer">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Hacer
              <% if (nc.hacer) { %><span class="nav-badge"><%= nc.hacer %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/agendar" data-page="/agendar">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Agendar
              <% if (nc.agendar) { %><span class="nav-badge"><%= nc.agendar %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/delegar" data-page="/delegar">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
              Delegar
              <% if (nc.delegar) { %><span class="nav-badge"><%= nc.delegar %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/desglosar" data-page="/desglosar">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              Desglosar
              <% if (nc.desglosar) { %><span class="nav-badge"><%= nc.desglosar %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/someday" data-page="/someday">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
              Algún Día
              <% if (nc.someday) { %><span class="nav-badge"><%= nc.someday %></span><% } %>
            </span>
          </a>
          <a class="nav-link" href="/no-hacer" data-page="/no-hacer">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
              No hacer
            </span>
          </a>

          <% if (featureFlags && featureFlags.weekly_review) { %>
          <a class="nav-link relative" href="/weekly-review" data-page="/weekly-review">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              Revisión
              <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse-dot"></span>
            </span>
          </a>
          <% } %>
        </nav>

        <!-- Right side -->
        <div class="ml-auto flex items-center gap-1 shrink-0">
          <% if (featureFlags && featureFlags.command_palette) { %>
          <button id="cmd-palette-btn" aria-label="Búsqueda de comandos (Cmd+K)" class="hidden md:flex items-center gap-1.5 px-2 py-1 rounded-lg text-xs text-surface-500 dark:text-surface-400 border border-surface-200 dark:border-surface-700 hover:border-surface-300 dark:hover:border-surface-600 hover:text-surface-700 dark:hover:text-surface-200 transition-colors">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span>Cmd+K</span>
          </button>
          <% } %>

          <% if (useSupabase && authUser) { %>
            <div class="relative hidden md:block">
              <button id="user-menu-btn" class="flex items-center gap-1.5 px-2 py-1 rounded-lg text-xs text-surface-600 dark:text-surface-400 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors max-w-[160px]">
                <div class="w-6 h-6 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 flex items-center justify-center text-[10px] font-bold uppercase shrink-0">
                  <%= (authUser.email || 'U')[0] %>
                </div>
                <span class="truncate hidden lg:block"><%= authUser.email %></span>
              </button>
              <div id="user-menu" class="hidden absolute right-0 top-full mt-1 w-48 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-xl shadow-lg py-1 z-30">
                <div class="px-3 py-2 border-b border-surface-100 dark:border-surface-700">
                  <div class="text-xs text-surface-500 dark:text-surface-400 truncate"><%= authUser.email %></div>
                </div>
                <a href="/settings" class="block px-3 py-2 text-sm text-surface-700 dark:text-surface-300 hover:bg-surface-50 dark:hover:bg-surface-700">Configuración</a>
                <form method="POST" action="/auth/logout">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="w-full text-left px-3 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Cerrar sesión</button>
                </form>
              </div>
            </div>
          <% } %>
          <button id="theme-toggle" aria-label="Cambiar tema" class="p-2 rounded-lg hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors text-surface-500 dark:text-surface-400">
            <svg id="theme-icon-moon" class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <svg id="theme-icon-sun" class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </button>
          <button id="nav-hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-nav" class="md:hidden p-2 rounded-lg hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors text-surface-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>

      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-nav" class="hidden md:hidden border-t border-surface-200 dark:border-surface-800 bg-white dark:bg-surface-900">
      <div class="max-w-6xl mx-auto px-4 py-2 flex flex-col gap-0.5">
        <% if (useSupabase && authUser) { %>
          <div class="flex items-center justify-between py-2 border-b border-surface-100 dark:border-surface-800 mb-1">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 flex items-center justify-center text-xs font-bold uppercase">
                <%= (authUser.email || 'U')[0] %>
              </div>
              <span class="text-xs text-surface-500 dark:text-surface-400 truncate max-w-[200px]"><%= authUser.email %></span>
            </div>
            <form method="POST" action="/auth/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="text-xs px-2 py-1 rounded-lg text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">Salir</button>
            </form>
          </div>
        <% } %>
        <% const nm = navCounts || {}; %>
        <a class="nav-link-mobile" href="/" data-page="/">Dashboard</a>
        <a class="nav-link-mobile" href="/collect" data-page="/collect">
          Collect <% if (nm.collect) { %><span class="nav-badge-alert ml-auto"><%= nm.collect %></span><% } %>
        </a>
        <a class="nav-link-mobile" href="/hacer" data-page="/hacer">Hacer <% if (nm.hacer) { %><span class="nav-badge ml-auto"><%= nm.hacer %></span><% } %></a>
        <a class="nav-link-mobile" href="/agendar" data-page="/agendar">Agendar <% if (nm.agendar) { %><span class="nav-badge ml-auto"><%= nm.agendar %></span><% } %></a>
        <a class="nav-link-mobile" href="/delegar" data-page="/delegar">Delegar <% if (nm.delegar) { %><span class="nav-badge ml-auto"><%= nm.delegar %></span><% } %></a>
        <a class="nav-link-mobile" href="/desglosar" data-page="/desglosar">Desglosar <% if (nm.desglosar) { %><span class="nav-badge ml-auto"><%= nm.desglosar %></span><% } %></a>
        <a class="nav-link-mobile" href="/someday" data-page="/someday">Algún Día <% if (nm.someday) { %><span class="nav-badge ml-auto"><%= nm.someday %></span><% } %></a>
        <a class="nav-link-mobile" href="/no-hacer" data-page="/no-hacer">No hacer</a>
        <a class="nav-link-mobile" href="/terminado" data-page="/terminado">Terminado</a>
        <a class="nav-link-mobile" href="/stats" data-page="/stats">Estadísticas</a>
        <% if (featureFlags && featureFlags.weekly_review) { %>
        <a class="nav-link-mobile text-brand-600 dark:text-brand-400 font-semibold" href="/weekly-review" data-page="/weekly-review">🔄 Revisión Semanal</a>
        <% } %>
        <a class="nav-link-mobile" href="/settings" data-page="/settings">Configuración</a>
      </div>
    </div>
  </header>
  <% } %>

  <div class="max-w-6xl mx-auto p-4 md:p-6">

    <% if (flash?.error) { %>
      <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-200 text-sm border border-red-200 dark:border-red-800 slide-up"><%= flash.error %></div>
    <% } %>
    <% if (flash?.success) { %>
      <div class="mb-4 p-3 rounded-lg bg-green-50 dark:bg-green-900/30 text-green-800 dark:text-green-200 text-sm border border-green-200 dark:border-green-800 slide-up"><%= flash.success %></div>
    <% } %>

    <main id="main-content" class="mt-2" tabindex="-1">
      <%- body %>
    </main>
  </div>

  <% if (!hideAppNav) { %>
  <!-- FAB - Universal capture button -->
  <button id="fab-capture" class="fab" aria-label="Captura rápida">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
  </button>

  <!-- FAB Dialog -->
  <dialog id="fab-dialog" class="w-full max-w-lg mx-auto mt-24 bg-white dark:bg-surface-900 rounded-2xl shadow-2xl border border-surface-200 dark:border-surface-700 p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm">
    <div class="p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold text-surface-900 dark:text-surface-100">Captura rápida</h2>
        <button id="fab-close" class="p-1 rounded-lg hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form method="POST" action="/collect/add" id="fab-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <textarea id="fab-input" name="input" rows="3" class="input-base resize-none" placeholder="Escribe una idea, tarea o recordatorio..." autofocus></textarea>
        <div class="flex justify-end gap-2 mt-3">
          <button type="button" id="fab-cancel" class="btn-secondary">Cancelar</button>
          <button type="submit" class="btn-primary">Agregar a Collect</button>
        </div>
      </form>
    </div>
  </dialog>
  <% } %>

  <!-- Scripts comunes -->
  <script nonce="<%= cspNonce %>" src="/public/js/toast.js"></script>
  <script nonce="<%= cspNonce %>" src="/public/js/utils.js"></script>

  <% if (!hideAppNav && featureFlags && featureFlags.command_palette) { %>
  <script nonce="<%= cspNonce %>" src="/public/js/command-palette.js"></script>
  <% } %>

  <script nonce="<%= cspNonce %>">
    // Active nav indicator
    (function () {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link, .nav-link-mobile').forEach(function (link) {
        if (link.dataset.page === path) link.classList.add('nav-active');
      });
    })();

    // Hamburger menu toggle
    (function () {
      const hamburger = document.getElementById('nav-hamburger');
      const mobileNav = document.getElementById('mobile-nav');
      if (!hamburger || !mobileNav) return;
      hamburger.addEventListener('click', function () {
        const isOpen = !mobileNav.classList.contains('hidden');
        mobileNav.classList.toggle('hidden');
        hamburger.setAttribute('aria-expanded', String(!isOpen));
      });
    })();

    // User menu dropdown
    (function () {
      const btn = document.getElementById('user-menu-btn');
      const menu = document.getElementById('user-menu');
      if (!btn || !menu) return;
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });
      document.addEventListener('click', function () {
        menu.classList.add('hidden');
      });
    })();

    // FAB dialog
    (function () {
      const fab = document.getElementById('fab-capture');
      const dialog = document.getElementById('fab-dialog');
      const closeBtn = document.getElementById('fab-close');
      const cancelBtn = document.getElementById('fab-cancel');
      const input = document.getElementById('fab-input');
      if (!fab || !dialog) return;

      fab.addEventListener('click', function () {
        dialog.showModal();
        if (input) setTimeout(() => input.focus(), 50);
      });

      function closeDialog() {
        dialog.close();
        if (input) input.value = '';
      }

      if (closeBtn) closeBtn.addEventListener('click', closeDialog);
      if (cancelBtn) cancelBtn.addEventListener('click', closeDialog);

      dialog.addEventListener('click', function (e) {
        if (e.target === dialog) closeDialog();
      });

      dialog.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDialog();
      });
    })();
  </script>

  <!-- PWA Service Worker -->
  <script nonce="<%= cspNonce %>">
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js').catch(function () {});
      });
    }
  </script>

  <!-- Flash toasts -->
  <% if (flash?.error) { %>
    <script nonce="<%= cspNonce %>">
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof toast !== 'undefined') toast.error(<%- JSON.stringify(String(flash.error || '')) %>);
      });
    </script>
  <% } %>
  <% if (flash?.success) { %>
    <script nonce="<%= cspNonce %>">
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof toast !== 'undefined') toast.success(<%- JSON.stringify(String(flash.success || '')) %>);
      });
    </script>
  <% } %>
</body>
</html>
