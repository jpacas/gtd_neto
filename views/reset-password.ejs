<div class="max-w-md mx-auto bg-white border rounded-xl p-5">
  <h2 class="text-lg font-semibold">Nueva contraseña</h2>
  <p class="text-sm text-slate-600 mt-1">Ingresa tu nueva contraseña para GTD_Neto.</p>

  <% if (locals.message) { %>
    <div class="mt-3 px-3 py-2 rounded-lg border border-blue-200 bg-blue-50 text-sm text-blue-700"><%= message %></div>
  <% } %>

  <% if (!locals.message) { %>
  <form method="POST" action="/auth/update-password" class="mt-4 space-y-3" id="resetForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div>
      <label for="reset-password" class="text-xs text-slate-500">Nueva contraseña (mínimo 6 caracteres)</label>
      <input id="reset-password" type="password" name="password" minlength="6" required autocomplete="new-password" class="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" />
    </div>
    <button type="submit" id="resetBtn" class="w-full rounded-lg bg-blue-600 text-white px-4 py-2 hover:bg-blue-700 transition-colors">Actualizar contraseña</button>
  </form>

  <script nonce="<%= cspNonce %>">
    document.addEventListener('DOMContentLoaded', function() {
      document.getElementById('resetForm')?.addEventListener('submit', function() {
        LoadingManager.show(document.getElementById('resetBtn'));
      });
      setupFormValidation('resetForm', {
        password: {
          required: true,
          minLength: 6,
          requiredMessage: 'La contraseña es requerida',
          minLengthMessage: 'La contraseña debe tener al menos 6 caracteres'
        }
      });
    });
  </script>
  <% } %>

  <div class="mt-4 text-sm text-slate-600">
    <a href="/login" class="text-blue-600 hover:underline">Volver al login</a>
  </div>
</div>
