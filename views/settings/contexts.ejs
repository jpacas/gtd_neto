<div class="space-y-4">
  <div class="flex items-center gap-2">
    <a href="/settings" class="text-surface-400 hover:text-surface-600 dark:hover:text-surface-300">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-xl font-bold text-surface-900 dark:text-surface-50">Contextos</h1>
  </div>

  <!-- System contexts (read-only) -->
  <div class="card p-5">
    <h2 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">Contextos del sistema</h2>
    <div class="flex flex-wrap gap-2">
      <% for (const ctx of systemContexts) { %>
        <span class="context-badge"><%= ctx %></span>
      <% } %>
    </div>
    <p class="text-xs text-surface-400 dark:text-surface-500 mt-2">Estos contextos están disponibles para todos los usuarios.</p>
  </div>

  <!-- Custom contexts -->
  <div class="card p-5">
    <h2 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">Contextos personalizados</h2>

    <% if (customContexts.length > 0) { %>
      <div class="flex flex-wrap gap-2 mb-4">
        <% for (const ctx of customContexts) { %>
          <div class="flex items-center gap-1.5">
            <span class="context-badge"><%= ctx.value %></span>
            <form method="POST" action="/settings/contexts/<%= ctx.id %>/delete" class="inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="text-surface-300 hover:text-red-500 transition-colors" aria-label="Eliminar contexto">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </form>
          </div>
        <% } %>
      </div>
    <% } %>

    <form method="POST" action="/settings/contexts/add" class="flex gap-2">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="text" name="context" placeholder="@micontexto" class="input-base max-w-xs" pattern="^@[a-záéíóúñA-Z0-9_-]{1,30}$" />
      <button type="submit" class="btn-primary shrink-0">Agregar</button>
    </form>
    <p class="text-xs text-surface-400 dark:text-surface-500 mt-1.5">Formato: @palabra (ej: @viaje, @cliente-acme)</p>
  </div>
</div>
