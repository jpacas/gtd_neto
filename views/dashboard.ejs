<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-xl font-bold text-surface-900 dark:text-surface-50">Tu sistema GTD</h1>
      <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5">Vista general de todas las áreas de tu flujo.</p>
    </div>
    <a href="/weekly-review" class="hidden sm:flex items-center gap-2 px-3 py-2 rounded-xl bg-brand-500 text-white text-sm font-medium hover:bg-brand-600 transition-all shadow-sm hover:shadow-md">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      Revisión Semanal
      <span class="w-2 h-2 rounded-full bg-white/60 animate-pulse-dot"></span>
    </a>
  </div>

  <!-- Stat cards grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
    <% for (const c of cards) { %>
      <a href="<%= c.href %>" class="group card-hover p-4 flex flex-col gap-1">
        <div class="flex items-start justify-between">
          <div class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wide"><%= c.label %></div>
          <% if (c.count > 0) { %>
            <div class="text-xs font-bold px-1.5 py-0.5 rounded-md bg-surface-100 dark:bg-surface-700 text-surface-600 dark:text-surface-300 tabular-nums"><%= c.count %></div>
          <% } %>
        </div>
        <div class="text-2xl font-bold text-surface-900 dark:text-surface-50 tabular-nums group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
          <%= c.count %>
        </div>
        <% if (c.hint) { %><div class="text-xs text-surface-400 dark:text-surface-500 leading-tight"><%= c.hint %></div><% } %>
      </a>
    <% } %>
  </div>

  <!-- GTD flow reference + weekly review CTA -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="md:col-span-2 card p-5">
      <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-100 mb-3 flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Flujo GTD
      </h3>
      <ol class="space-y-2">
        <li class="flex items-center gap-2.5 text-sm">
          <span class="w-5 h-5 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 text-[10px] font-bold flex items-center justify-center shrink-0">1</span>
          <span class="text-surface-700 dark:text-surface-300">Captura todo en <a href="/collect" class="text-brand-600 dark:text-brand-400 hover:underline font-medium">Collect</a>.</span>
        </li>
        <li class="flex items-center gap-2.5 text-sm">
          <span class="w-5 h-5 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 text-[10px] font-bold flex items-center justify-center shrink-0">2</span>
          <span class="text-surface-700 dark:text-surface-300">Asigna destino: Hacer, Agendar, Delegar, Desglosar, Algún Día o No hacer.</span>
        </li>
        <li class="flex items-center gap-2.5 text-sm">
          <span class="w-5 h-5 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 text-[10px] font-bold flex items-center justify-center shrink-0">3</span>
          <span class="text-surface-700 dark:text-surface-300">Ejecuta desde cada sección. Revisa semanalmente.</span>
        </li>
      </ol>
    </div>

    <div class="card p-5 bg-gradient-to-br from-brand-50 to-white dark:from-brand-900/20 dark:to-surface-800 border-brand-200 dark:border-brand-800 flex flex-col gap-3">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-brand-100 dark:bg-brand-900/40 text-brand-600 dark:text-brand-400 flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-100">Revisión Semanal</h3>
      </div>
      <p class="text-xs text-surface-600 dark:text-surface-400 leading-relaxed">El corazón del sistema GTD. Revisa, limpia y planifica cada semana.</p>
      <a href="/weekly-review" class="btn-primary text-xs justify-center">Iniciar revisión →</a>
    </div>
  </div>
</div>
